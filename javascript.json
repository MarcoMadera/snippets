{
  "Console Log": {
    "prefix": "l",
    "body": [
      "console.log($1)"
    ]
  },
  "QuerySelector": {
    "prefix": "qs",
    "body": [
      "${1:document}.querySelector('${2:selector}');"
    ]
  },
  "GetElementById": {
    "prefix": "gi",
    "body": [
      "${1:document}.getElementById('${2:id}')"
    ]
  },
  "GetElementsByClassName": {
    "prefix": "gc",
    "body": [
      "${1:document}.getElementsByClassName('${2:class}')"
    ]
  },
  "GetElementByClassName": {
    "prefix": "gt",
    "body": [
      "${1:document}.getElementsByTagName('${2:tag}');"
    ]
  },
  "Add Event Listener": {
    "prefix": "ae",
    "body": [
      "${1:document}.addEventListener('${2:event}', function(e) {",
      "  ${0:// body...}",
      "})"
    ]
  },
  "Promise": {
    "prefix": "prom",
    "body": [
      "const ${1:name}Promise = ($2) => {",
      "  return new Promise((resolve, reject) => {",
      "    if ($3) {",
      "      resolve($4);",
      "    } else {",
      "      reject($5);",
      "    }",
      "  });",
      "}"
    ]
  },
  "Call Promise": {
    "prefix": "cprom",
    "body": [
      "${1:name}Promise()",
      "  .then(response => $2)",
      "  .catch(error => $3);",
      "  .finally(() => $4);"
    ]
  },
  "Destructure": {
    "prefix": "d",
    "body": [
      "const { $1 } = $0"
    ]
  },
  "Get Data": {
    "prefix": "gd",
    "body": [
      "async function ${1:name}($2) {",
      "  const url = $3;",
      "  const response = await fetch(url);",
      "  const data = await response.json();",
      "  return data;"
    ]
  },
  "Try/Catch": {
    "prefix": "tr",
    "body": [
      "try {",
      "  $1",
      "} catch (err) {",
      "  $0",
      "}"
    ]
  },
  "To-Do": {
    "prefix": "todo",
    "body": [
      "// TODO: $1"
    ]
  },
  "Comment": {
    "prefix": "c",
    "body": [
      "/**",
      "  $1.",
      " */"
    ]
  },
  "Function": {
    "prefix": "fc",
    "body": [
      "/**",
      "  $1 $2.",
      " */",
      "",
      "function $1($3) {",
      "  $0",
      "}"
    ]
  },
  "Generator": {
  "prefix": "gen",
    "body": [
      "function* ${1:name}() {",
      "  if ($2) {",
      "    yield '${3:hello}';",
      "  }",
      "  if($4) {",
      "    yield '${5:world}'",
      "  }",
      "}",
      "",
      "const generator${1:name} = ${1:name}();",
      "console.log(generator${1:name}.next().value)",
      "console.log(generator${1:name}.next().value)"
    ]
  },
  "Function Without Comment": {
    "prefix": "f",
    "body": [
      "function $1($2) {",
      "  $0",
      "}"
    ]
  },
  "Import": {
    "prefix": "i",
    "body": [
      "import $1 from '${2:$1}'"
    ]
  },
  "Import Component": {
    "prefix": "ic",
    "body": [
      "import $1 from './$1'"
    ]
  },
  "Set TimeOut": {
    "prefix": "st",
    "body": [
      "setTimeout(()=>$1,${2:delay})"
    ]
  }  
}
